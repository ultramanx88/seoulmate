# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# API runtime
NODE_ENV="development"
PORT="8080"
APP_VERSION="development"
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
TRUST_PROXY="false"
SHUTDOWN_TIMEOUT_MS="10000"

# PostgreSQL
POSTGRES_DB="seoulmate"
POSTGRES_USER="seoulmate"
POSTGRES_PASSWORD="change-me"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://seoulmate:change-me@localhost:5432/seoulmate"
DATABASE_SSL="false"
DATABASE_POOL_MIN="2"
DATABASE_POOL_MAX="20"

# Redis
REDIS_PASSWORD="change-me"
REDIS_PORT="6379"
REDIS_URL="redis://:change-me@localhost:6379"
REDIS_REQUIRED="false"

# Firebase backfill (Firebase remains enabled during migration)
FIREBASE_PROJECT_ID="studio-2556650652-f3711"
FIRESTORE_DATABASE_ID="ai-studio-554b0bce-d0ca-41ea-a58d-589a73ebfb99"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
MIGRATION_DRY_RUN="true"
MIGRATION_PAGE_SIZE="200"

# Docker published ports
APP_PORT="8080"
