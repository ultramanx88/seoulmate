# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend API origin for local Vite dev. Leave empty in production when app/API share one origin.
VITE_API_URL="http://localhost:8080"

# API runtime
NODE_ENV="development"
PORT="8080"
APP_VERSION="development"
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
TRUST_PROXY="false"
SHUTDOWN_TIMEOUT_MS="10000"

# Custom Fastify/Express auth session + OAuth providers
AUTH_SESSION_SECRET="replace-with-at-least-32-random-chars"
AUTH_SUCCESS_URL="http://localhost:3000"
AUTH_FAILURE_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8080/v1/auth/google/callback"
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""
LINE_REDIRECT_URI="http://localhost:8080/v1/auth/line/callback"
KAKAO_REST_API_KEY=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="http://localhost:8080/v1/auth/kakao/callback"
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI="http://localhost:8080/v1/auth/naver/callback"

# PostgreSQL
POSTGRES_DB="seoulmate"
POSTGRES_USER="seoulmate"
POSTGRES_PASSWORD="change-me"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://seoulmate:change-me@localhost:5432/seoulmate"
DATABASE_SSL="false"
DATABASE_POOL_MIN="2"
DATABASE_POOL_MAX="20"

# Redis
REDIS_PASSWORD="change-me"
REDIS_PORT="6379"
REDIS_URL="redis://:change-me@localhost:6379"
REDIS_REQUIRED="false"

# Docker published ports
APP_PORT="8080"
