APP_VERSION=kvm1
APP_BIND=127.0.0.1
APP_PORT=3220
CORS_ORIGINS=https://seoulmate.example.com
APP_URL=https://seoulmate.example.com
AUTH_SESSION_SECRET=replace-with-at-least-32-random-chars
AUTH_SUCCESS_URL=https://seoulmate.example.com
AUTH_FAILURE_URL=https://seoulmate.example.com

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://seoulmate.example.com/v1/auth/google/callback

LINE_CHANNEL_ID=replace-with-line-channel-id
LINE_CHANNEL_SECRET=replace-with-line-channel-secret
LINE_REDIRECT_URI=https://seoulmate.example.com/v1/auth/line/callback

KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://seoulmate.example.com/v1/auth/kakao/callback

NAVER_CLIENT_ID=replace-with-naver-client-id
NAVER_CLIENT_SECRET=replace-with-naver-client-secret
NAVER_REDIRECT_URI=https://seoulmate.example.com/v1/auth/naver/callback

POSTGRES_DB=seoulmate
POSTGRES_USER=seoulmate
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

REDIS_PASSWORD=replace-with-a-strong-redis-password
SHUTDOWN_TIMEOUT_MS=10000

GEMINI_API_KEY=replace-with-gemini-api-key
